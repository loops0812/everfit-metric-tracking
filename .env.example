NODE_ENV=development
PORT=3000
APP_NAME="Everfit Metric Tracking API"
API_PREFIX=api
APP_VERSION=1.0.0

# Swagger configuration
SWAGGER_ENABLED=true
SWAGGER_TITLE="Everfit Metric Tracking API"
SWAGGER_DESCRIPTION="API documentation for Everfit Metric Tracking"
SWAGGER_PREFIX=api-docs

# MongoDB configuration
MONGO_URI=mongodb://localhost:27017 # Update to use environment variable for MongoDB URI
# MONGO_URI=mongodb://mongo:27017 # Use this line if you want to connect to MongoDB service defined in docker-compose.yml
MONGO_DB_NAME=everfit-metrics
